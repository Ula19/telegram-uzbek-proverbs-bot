# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Юзернейм бота (без @) — для рекламной подписи под мақолом и в помощи.
# Если пусто — подпись не показывается.
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_proverbs
DB_USER=bot_4_proverbs
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== КЭШ ====================

# TTL для доменного кэша (дни)
CACHE_TTL_DAYS=1
